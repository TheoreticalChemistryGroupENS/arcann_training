units metal
boundary p p p
atom_style atomic

#atom_modify     map yes # needed for MACE for LAMMPS
newton          on

# units metal: time (ps), energy (eV), distance (Ang)

neighbor 2.0 bin
neigh_modify every 10 delay 0 check no

read_data _R_DATA_FILE_

pair_style       mliap unified _R_MODEL_FILES_ 0
pair_coeff       * * _R_ATOM_LABELS_
#pair_style      mace no_domain_decomposition # when not using many MPI processes
#pair_coeff      * * _R_MODEL_FILES_ _R_ATOM_LABELS_
#pair_style      symmetrix/mace
#pair_coeff      * * _R_MODEL_FILES_ _R_ATOM_LABELS_

timestep _R_TIMESTEP_

dump dcd all dcd _R_PRINT_FREQ_ _R_DCD_OUT_

thermo_style custom step time etotal ke pe temp press vol density cella cellb cellc cpuremain
thermo_modify flush yes
thermo _R_PRINT_FREQ_

velocity all create _R_TEMPERATURE_ _R_SEED_VEL_ dist gaussian

fix 1 all nve
fix 2 all _R_TEMPERATURE_ _R_TEMPERATURE_ $(100.0*dt) _R_SEED_THER_
fix 3 all momentum 1 linear 1 1 1

run _R_NUMBER_OF_STEPS_ # there must be only one space between run and the variable

write_restart _R_RESTART_OUT_
